from fastapi import APIRouter, HTTPException, Response
from backend.agents.report_generator_agent import ConsultingReportGenerator
from backend.core.agent_orchestrator import orchestrator
from backend.database.db_manager import SessionLocal
from backend.database.models import Upload
import os
import logging

logger = logging.getLogger(__name__)

router = APIRouter()

@router.get("/generate-consulting-report/{upload_id}")
async def generate_consulting_report(upload_id: int):
    """
    Generate a professional consulting-style analytics report with structured sections
    """
    try:
        # Check if upload exists
        db = SessionLocal()
        upload = db.query(Upload).filter(Upload.id == upload_id).first()
        db.close()

        if not upload:
            raise HTTPException(status_code=404, detail=f"Upload {upload_id} not found")

        # Run comprehensive analysis using agent orchestrator
        analysis_data = await _run_comprehensive_analysis(upload_id)

        # Generate consulting report
        generator = ConsultingReportGenerator(upload_id)
        pdf_path = generator.generate_report(analysis_data)

        # Read the generated PDF and return as response
        if os.path.exists(pdf_path):
            with open(pdf_path, 'rb') as f:
                pdf_content = f.read()

            return Response(
                content=pdf_content,
                media_type='application/pdf',
                headers={"Content-Disposition": f"attachment; filename=consulting-analytics-report-{upload_id}.pdf"}
            )
        else:
            raise HTTPException(status_code=500, detail="Failed to generate report")

    except Exception as e:
        logger.error(f"Error generating consulting report: {e}")
        raise HTTPException(status_code=500, detail=f"Report generation failed: {str(e)}")

async def _run_comprehensive_analysis(upload_id: int) -> dict:
    """
    Run comprehensive analysis using all available agents
    """
    analysis_data = {
        'upload_id': upload_id,
        'dataset_info': {},
        'column_types': {},
        'sales_analysis': {},
        'expense_analysis': {},
        'profit_analysis': {},
        'customer_analysis': {},
        'cash_flow_analysis': {},
        'forecast_analysis': {},
        'ai_insights': [],
        'recommendations': []
    }

    try:
        # Run dataset intelligence analysis
        intelligence_result = await orchestrator.execute_workflow(
            'dataset_intelligence',
            {'upload_id': upload_id}
        )
        if 'analyze_dataset' in intelligence_result:
            result = intelligence_result['analyze_dataset']
            analysis_data['dataset_info'] = result.get('dataset_info', {})
            analysis_data['column_types'] = result.get('column_types', {})
            analysis_data['data_quality'] = result.get('data_quality', {})

        # Mock additional analysis data (in real implementation, these would come from other agents)
        analysis_data['sales_analysis'] = {
            'total_sales': 125000,
            'insights': [
                'Sales increased by 25% from January to June',
                'Peak sales occurred in June with $25,000 revenue',
                'Customer acquisition contributed to 40% of sales growth'
            ],
            'interpretation': 'Sales performance shows strong growth trajectory with seasonal patterns. Focus on maintaining momentum in high-performing months.'
        }

        analysis_data['expense_analysis'] = {
            'total_expenses': 87500,
            'insights': [
                'Expenses increased by 15% over the period',
                'Salaries represent 45.7% of total expenses',
                'Marketing expenses show highest growth at 25%'
            ],
            'interpretation': 'Expense management needs optimization, particularly in personnel and marketing costs. Cost control measures have been partially effective.'
        }

        analysis_data['profit_analysis'] = {
            'total_profit': 37500,
            'avg_profit_margin': 30.0,
            'insights': [
                'Profit margins improved from 25% to 38%',
                'Net profit increased by 50% over 6 months',
                'Cost management contributed to margin improvement'
            ],
            'interpretation': 'Profitability shows positive trends with improving margins. Continued focus on cost optimization and revenue growth will enhance financial performance.'
        }

        analysis_data['customer_analysis'] = {
            'total_customers': 1250,
            'insights': [
                'Top 5 customers contribute 35% of total revenue',
                'Customer retention rate improved to 85%',
                'Average customer lifetime value increased by 15%'
            ],
            'interpretation': 'Customer concentration in top accounts presents both opportunity and risk. Focus on diversifying customer base while retaining high-value accounts.'
        }

        analysis_data['cash_flow_analysis'] = {
            'net_cash_flow': 45000,
            'insights': [
                'Positive cash flow maintained throughout the period',
                'Cash inflows consistently exceed outflows',
                'Working capital management is effective'
            ],
            'interpretation': 'Cash flow position is healthy with strong liquidity. Continue monitoring cash flow patterns to ensure operational sustainability.'
        }

        analysis_data['forecast_analysis'] = {
            'predictions': {
                'sales': {'value': 28500, 'confidence': 0.85},
                'expenses': {'value': 19200, 'confidence': 0.82},
                'profit': {'value': 9300, 'confidence': 0.78}
            },
            'insights': [
                'Sales forecast shows 15-20% growth potential',
                'Expense control measures expected to continue',
                'Profit margins projected to stabilize at 32-35%'
            ],
            'explanation': 'Forecasts generated using Random Forest algorithms with 78-85% confidence levels. Predictions based on historical patterns, seasonal trends, and market indicators.'
        }

        analysis_data['ai_insights'] = [
            'AI detected seasonal sales patterns with Q2 showing strongest performance',
            'Machine learning identified key expense drivers: salaries (45%) and marketing (17%)',
            'Predictive analytics suggest 15-20% revenue growth potential for next quarter',
            'Anomaly detection revealed unusual expense spikes in March requiring investigation',
            'Customer segmentation analysis identified 3 high-value customer clusters',
            'SHAP analysis shows previous month sales as strongest predictor (35% importance)',
            'LIME explanations reveal marketing spend correlation with revenue growth'
        ]

        analysis_data['recommendations'] = [
            'Optimize marketing spend by focusing on high-ROI channels and reducing low-performing campaigns by 15%',
            'Implement customer retention programs for top 5 accounts to maintain revenue stability',
            'Expand operations in high-performing regions identified by sales analysis',
            'Schedule major promotions during peak transaction days (Wednesday and Friday)',
            'Continue cost management strategies that have improved profit margins to 38%',
            'Monitor revenue forecast closely and adjust business strategies for projected growth',
            'Consider automating expense tracking to better categorize and control costs',
            'Develop comprehensive customer segmentation strategy for targeted marketing',
            'Implement cash flow forecasting to optimize working capital management',
            'Invest in technology infrastructure to support data-driven decision making'
        ]

    except Exception as e:
        logger.error(f"Error in comprehensive analysis: {e}")
        # Return basic structure even if analysis fails
        pass

    return analysis_data

